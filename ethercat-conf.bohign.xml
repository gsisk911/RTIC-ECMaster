<?xml version="1.0" encoding="UTF-8"?>
<!--
  lcec-style EtherCAT bus configuration: ONE YAKO/Bohign drive.

  Source device : Bohign_MS_ECAT_V2.5.xml  ->  "YAKO ESD2505PE"
                  Vendor  0x00000994 (Shenzhen YAKO)
                  Product 0x00001B00
                  Rev     0x00000001
  Mapping       : stock RxPDO1 (0x1600) + TxPDO1 (0x1A00), verbatim from the ESI.
                  This mapping is identical across the MS/ESD common-layout family,
                  so to target another model change only the slave `pid`.

  Consumed at COMPILE TIME by scripts/generate_ethercat_config.py, which emits
  src/ethercat/config/generated.rs. It is NOT parsed on the MCU.

  Cycle: appTimePeriod is the master cycle in nanoseconds.
         10000000 ns = 100 Hz (current bring-up test)
           250000 ns = 4 kHz  (target; just change appTimePeriod)
         sync0Cycle="*1" = SYNC0 fires once per appTimePeriod.
-->
<masters>
  <master idx="0" appTimePeriod="10000000" refClockSyncCycles="1" refClockSlaveIdx="0">
    <slave idx="0" type="generic" vid="0x00000994" pid="0x00001B00" configPdos="true" name="drive0">

      <!-- Distributed Clocks: SYNC0 enabled (DC-Synchron op-mode 0x0300). -->
      <dcConf assignActivate="0x0300" sync0Cycle="*1" sync0Shift="0"/>

      <!-- Init SDO: Modes of Operation = 8 (CSP). Mirrors the ESI PS InitCmd. -->
      <sdoConfig idx="0x6060" subIdx="0x00">
        <sdoDataRaw data="08"/>
      </sdoConfig>

      <!-- SM2 / RxPDO1 0x1600 : outputs (master -> drive), 16 bytes. -->
      <syncManager idx="2" dir="out">
        <pdo idx="1600">
          <pdoEntry idx="6040" subIdx="00" bitLen="16" halType="u32" halPin="drive0-controlword"/>
          <pdoEntry idx="607a" subIdx="00" bitLen="32" halType="s32" halPin="drive0-target-position"/>
          <pdoEntry idx="60ff" subIdx="00" bitLen="32" halType="s32" halPin="drive0-target-velocity"/>
          <pdoEntry idx="60b8" subIdx="00" bitLen="16" halType="u32" halPin="drive0-touch-probe-function"/>
          <pdoEntry idx="60fe" subIdx="01" bitLen="32" halType="u32" halPin="drive0-digital-outputs"/>
        </pdo>
      </syncManager>

      <!-- SM3 / TxPDO1 0x1A00 : inputs (drive -> master), 39 bytes. -->
      <syncManager idx="3" dir="in">
        <pdo idx="1a00">
          <pdoEntry idx="603f" subIdx="00" bitLen="16" halType="u32" halPin="drive0-error-code"/>
          <pdoEntry idx="6041" subIdx="00" bitLen="16" halType="u32" halPin="drive0-statusword"/>
          <pdoEntry idx="6064" subIdx="00" bitLen="32" halType="s32" halPin="drive0-actual-position"/>
          <pdoEntry idx="60fd" subIdx="00" bitLen="32" halType="u32" halPin="drive0-digital-inputs"/>
          <pdoEntry idx="606c" subIdx="00" bitLen="32" halType="s32" halPin="drive0-actual-velocity"/>
          <pdoEntry idx="60f4" subIdx="00" bitLen="32" halType="s32" halPin="drive0-follow-error"/>
          <pdoEntry idx="60b9" subIdx="00" bitLen="16" halType="u32" halPin="drive0-touch-probe-status"/>
          <pdoEntry idx="60ba" subIdx="00" bitLen="32" halType="s32" halPin="drive0-touch-probe-pos1-positive"/>
          <pdoEntry idx="60bb" subIdx="00" bitLen="32" halType="s32" halPin="drive0-touch-probe-pos1-negative"/>
          <pdoEntry idx="60bc" subIdx="00" bitLen="32" halType="s32" halPin="drive0-touch-probe-pos2-positive"/>
          <pdoEntry idx="60bd" subIdx="00" bitLen="32" halType="s32" halPin="drive0-touch-probe-pos2-negative"/>
          <pdoEntry idx="6061" subIdx="00" bitLen="8" halType="s32" halPin="drive0-op-mode-display"/>
        </pdo>
      </syncManager>

    </slave>
  </master>
</masters>
